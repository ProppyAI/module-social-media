{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.harness.proppyai.com/deployment/v1/deployment.schema.json",
  "title": "HARNESS Deployment Config",
  "description": "Configuration for a HARNESS client deployment",
  "type": "object",
  "properties": {
    "vertical": {
      "type": "string",
      "description": "Vertical template name (must match a file in verticals/)"
    },
    "client": {
      "type": "string",
      "description": "Client identifier for this deployment"
    },
    "modules": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Module names to enable"
        },
        "config": {
          "type": "object",
          "additionalProperties": { "type": "object" },
          "description": "Per-module configuration overrides"
        }
      }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["supervised", "autonomous", "unrestricted"]
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "module": { "type": "string" },
              "access": { "type": "string" },
              "behavior": { "type": "string", "enum": ["allow", "deny", "ask"] }
            },
            "required": ["module", "access", "behavior"]
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "timeout": { "type": "number", "default": 30 },
        "enabled": { "type": "boolean", "default": true }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["mcp", "api"] },
          "transport": { "type": "string", "enum": ["stdio", "http", "sse"] },
          "url": { "type": "string" },
          "command": { "type": "string" },
          "args": { "type": "array", "items": { "type": "string" } },
          "required": { "type": "boolean", "default": false }
        },
        "required": ["type"]
      }
    },
    "channels": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" }
        }
      }
    },
    "entity_extensions": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "model": { "type": "string" },
    "auto_pr": { "type": "boolean" },
    "hybrid_threshold": { "type": "number" }
  }
}
